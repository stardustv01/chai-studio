{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chai.studio/schema/rational.v1.json",
  "title": "NormalizedRational",
  "type": "object",
  "additionalProperties": false,
  "required": ["numerator", "denominator"],
  "properties": {
    "numerator": { "type": "string", "pattern": "^-?(0|[1-9][0-9]{0,77})$" },
    "denominator": { "type": "string", "pattern": "^[1-9][0-9]{0,77}$" }
  }
}
