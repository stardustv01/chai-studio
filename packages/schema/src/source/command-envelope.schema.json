{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chai.studio/schema/command-envelope.v1.json",
  "title": "Chai Studio command envelope",
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._:-]{2,127}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "jsonValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/jsonValue" } }
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "sessionId"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["user", "codex", "system"] },
        "sessionId": { "$ref": "#/$defs/id" }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "common": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "commandId",
        "idempotencyId",
        "actor",
        "projectId",
        "correlationId",
        "issuedAt",
        "capability",
        "payloadVersion",
        "affectedEntityIds",
        "declaredScope",
        "validationOnly",
        "baseRevisionId",
        "authorizationId",
        "kind",
        "payload"
      ],
      "properties": {
        "schemaVersion": { "const": "1.0.0" },
        "commandId": { "$ref": "#/$defs/id" },
        "idempotencyId": { "$ref": "#/$defs/id" },
        "actor": { "$ref": "#/$defs/actor" },
        "projectId": { "$ref": "#/$defs/id" },
        "correlationId": { "$ref": "#/$defs/id" },
        "issuedAt": { "$ref": "#/$defs/timestamp" },
        "capability": { "$ref": "#/$defs/capability" },
        "payloadVersion": { "const": "1.0.0" },
        "affectedEntityIds": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "declaredScope": { "enum": ["read", "capture", "mutation", "source-edit", "destructive"] },
        "validationOnly": { "type": "boolean" },
        "baseRevisionId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "authorizationId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
        "kind": {
          "enum": [
            "read.inspect",
            "capture.create",
            "project.rename",
            "timeline.edit",
            "audio.edit",
            "language.edit",
            "annotation.edit",
            "review.edit",
            "timeline.replace",
            "asset.register",
            "asset.relink",
            "asset.replace",
            "asset.manifest.upsert",
            "source.edit",
            "history.undo",
            "history.redo",
            "version.create",
            "lifecycle.transition"
          ]
        },
        "payload": { "type": "object" }
      }
    },
    "readInspect": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "read.inspect" },
            "declaredScope": { "const": "read" },
            "baseRevisionId": { "type": "null" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["query"],
              "properties": { "query": { "type": "string", "minLength": 1, "maxLength": 1000 } }
            }
          }
        }
      ]
    },
    "captureCreate": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "capture.create" },
            "declaredScope": { "const": "capture" },
            "baseRevisionId": { "type": "null" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label"],
              "properties": { "label": { "type": "string", "minLength": 1, "maxLength": 200 } }
            }
          }
        }
      ]
    },
    "projectRename": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "project.rename" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title"],
              "properties": { "title": { "type": "string", "minLength": 1, "maxLength": 200 } }
            }
          }
        }
      ]
    },
    "timelineReplace": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "timeline.replace" },
            "declaredScope": { "const": "destructive" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "$ref": "#/$defs/id" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["timeline"],
              "properties": {
                "timeline": {
                  "$ref": "https://chai.studio/schema/project-documents.v1.json#/$defs/timeline"
                }
              }
            }
          }
        }
      ]
    },
    "timelineEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "timeline.edit" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation"],
              "properties": {
                "operation": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": { "kind": { "type": "string", "minLength": 1, "maxLength": 80 } },
                  "additionalProperties": { "$ref": "#/$defs/jsonValue" }
                }
              }
            }
          }
        }
      ]
    },
    "audioEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "audio.edit" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation"],
              "properties": {
                "operation": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": { "kind": { "type": "string", "pattern": "^audio\\." } },
                  "additionalProperties": { "$ref": "#/$defs/jsonValue" }
                }
              }
            }
          }
        }
      ]
    },
    "reviewEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "review.edit" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation"],
              "properties": {
                "operation": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": { "kind": { "type": "string", "pattern": "^review\\.[a-z.-]+$" } },
                  "additionalProperties": { "$ref": "#/$defs/jsonValue" }
                }
              }
            }
          }
        }
      ]
    },
    "languageEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "language.edit" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation"],
              "properties": {
                "operation": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": {
                    "kind": { "type": "string", "pattern": "^(language|transcript|caption)\\." }
                  },
                  "additionalProperties": { "$ref": "#/$defs/jsonValue" }
                }
              }
            }
          }
        }
      ]
    },
    "annotationEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "annotation.edit" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["operation"],
              "properties": {
                "operation": {
                  "type": "object",
                  "required": ["kind"],
                  "properties": {
                    "kind": {
                      "enum": ["annotation.create", "annotation.update", "annotation.delete"]
                    }
                  },
                  "additionalProperties": { "$ref": "#/$defs/jsonValue" }
                }
              }
            }
          }
        }
      ]
    },
    "assetRegister": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "asset.register" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["asset"],
              "properties": {
                "asset": {
                  "$ref": "https://chai.studio/schema/project-documents.v1.json#/$defs/assets/properties/assets/items"
                }
              }
            }
          }
        }
      ]
    },
    "assetRelink": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "asset.relink" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetId", "newPath", "observedContentHash"],
              "properties": {
                "assetId": { "$ref": "#/$defs/id" },
                "newPath": { "$ref": "#/$defs/relativePath" },
                "observedContentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          }
        }
      ]
    },
    "assetReplace": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "asset.replace" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["expectedContentHash", "asset"],
              "properties": {
                "expectedContentHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "asset": {
                  "$ref": "https://chai.studio/schema/project-documents.v1.json#/$defs/assets/properties/assets/items"
                }
              }
            }
          }
        }
      ]
    },
    "assetManifestUpsert": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "asset.manifest.upsert" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["manifestType", "asset", "content"],
              "properties": {
                "manifestType": { "enum": ["rights", "curation", "fonts"] },
                "asset": {
                  "$ref": "https://chai.studio/schema/project-documents.v1.json#/$defs/assets/properties/assets/items"
                },
                "content": { "type": "string", "minLength": 3, "maxLength": 5000000 }
              }
            }
          }
        }
      ]
    },
    "sourceEdit": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "source.edit" },
            "declaredScope": { "const": "source-edit" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "expectedHash", "content"],
              "properties": {
                "path": { "$ref": "#/$defs/relativePath" },
                "expectedHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "content": { "type": "string", "maxLength": 5000000 }
              }
            }
          }
        }
      ]
    },
    "historyMove": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "enum": ["history.undo", "history.redo"] },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["steps"],
              "properties": { "steps": { "type": "integer", "minimum": 1, "maximum": 100 } }
            }
          }
        }
      ]
    },
    "versionCreate": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "version.create" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "outputId"],
              "properties": {
                "name": { "enum": ["Draft", "Review", "Approved", "Delivery Candidate", "Delivered"] },
                "outputId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] }
              }
            }
          }
        }
      ]
    },
    "lifecycleTransition": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "lifecycle.transition" },
            "declaredScope": { "const": "mutation" },
            "baseRevisionId": { "$ref": "#/$defs/id" },
            "authorizationId": { "type": "null" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["to", "outputId", "evidenceHashes", "exceptionIds"],
              "properties": {
                "to": {
                  "enum": [
                    "rendered_unchecked",
                    "qa_failed",
                    "qa_warning",
                    "qa_passed",
                    "approved",
                    "delivered"
                  ]
                },
                "outputId": { "anyOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }] },
                "evidenceHashes": {
                  "type": "array",
                  "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "uniqueItems": true
                },
                "exceptionIds": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/id" },
                  "uniqueItems": true
                }
              }
            }
          }
        }
      ]
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/readInspect" },
    { "$ref": "#/$defs/captureCreate" },
    { "$ref": "#/$defs/projectRename" },
    { "$ref": "#/$defs/timelineEdit" },
    { "$ref": "#/$defs/audioEdit" },
    { "$ref": "#/$defs/languageEdit" },
    { "$ref": "#/$defs/annotationEdit" },
    { "$ref": "#/$defs/reviewEdit" },
    { "$ref": "#/$defs/timelineReplace" },
    { "$ref": "#/$defs/assetRegister" },
    { "$ref": "#/$defs/assetRelink" },
    { "$ref": "#/$defs/assetReplace" },
    { "$ref": "#/$defs/assetManifestUpsert" },
    { "$ref": "#/$defs/sourceEdit" },
    { "$ref": "#/$defs/historyMove" },
    { "$ref": "#/$defs/versionCreate" },
    { "$ref": "#/$defs/lifecycleTransition" }
  ]
}
